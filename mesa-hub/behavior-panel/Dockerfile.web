FROM public.ecr.aws/docker/library/node:22-bookworm-slim AS portal-builder

WORKDIR /app

RUN npm install -g pnpm

# 拆分 COPY — 复制所有 workspace package.json（pnpm 需要完整 workspace 声明）
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml ./
COPY fabrication/skin/package.json fabrication/skin/package.json
COPY mesa-hub/behavior-panel/web/package.json mesa-hub/behavior-panel/web/package.json
COPY mesa-hub/portal/web/package.json mesa-hub/portal/web/package.json
COPY sweetwater/black-ridge/web/package.json sweetwater/black-ridge/web/package.json

RUN --mount=type=cache,id=pnpm-store,target=/root/.local/share/pnpm/store \
    pnpm install

# 复制 Portal + fabrication 源码
COPY fabrication/skin/ fabrication/skin/
COPY mesa-hub/portal/web/ mesa-hub/portal/web/

RUN cd mesa-hub/portal/web && pnpm run build

# ===== Behavior Panel builder =====
FROM public.ecr.aws/docker/library/node:22-bookworm-slim AS web-builder

WORKDIR /app

RUN npm install -g pnpm

# 同样复制所有 workspace package.json
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml ./
COPY fabrication/skin/package.json fabrication/skin/package.json
COPY mesa-hub/behavior-panel/web/package.json mesa-hub/behavior-panel/web/package.json
COPY mesa-hub/portal/web/package.json mesa-hub/portal/web/package.json
COPY sweetwater/black-ridge/web/package.json sweetwater/black-ridge/web/package.json

RUN --mount=type=cache,id=pnpm-store,target=/root/.local/share/pnpm/store \
    pnpm install

# 复制 Behavior Panel + fabrication 源码
COPY fabrication/skin/ fabrication/skin/
COPY mesa-hub/behavior-panel/web/ mesa-hub/behavior-panel/web/

WORKDIR /app/mesa-hub/behavior-panel/web
RUN pnpm run build

# ===== nginx =====
FROM public.ecr.aws/docker/library/nginx:alpine

# nginx:alpine 官方镜像内置 envsubst 模板机制，
# /etc/nginx/templates/ 下的 .template 文件会在启动时自动替换环境变量并输出到 /etc/nginx/conf.d/
COPY mesa-hub/behavior-panel/nginx.conf /etc/nginx/templates/default.conf.template

# Portal 静态文件 → 首页
COPY --from=portal-builder /app/mesa-hub/portal/web-dist /usr/share/nginx/html/portal

# Behavior Panel 静态文件 → /behavior-panel/
COPY --from=web-builder /app/mesa-hub/behavior-panel/web-dist /usr/share/nginx/html/behavior-panel

ENV MANAGER_UPSTREAM="agent-manager:8080"
ENV WS_TIMEOUT="3600s"

EXPOSE 80
